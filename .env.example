# Supabase — client-side (safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=

# The following are set in Supabase secrets only — never use on the client
# supabase secrets set BIBLE_API_KEY=...
BIBLE_API_KEY=

# supabase secrets set GEMINI_API_KEY=...
GEMINI_API_KEY=

# Generate with: npx web-push generate-vapid-keys
# supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=...
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
